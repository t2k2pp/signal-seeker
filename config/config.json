{
  "llm": {
    "endpoint": {
      "providerType": "llamacpp",
      "model": "gemma-4-31B-it-f16.gguf",
      "baseUrl": "http://192.168.1.201:9082/v1"
    },
    "deepEndpoint": {
      "providerType": "anthropic",
      "model": "claude-opus-4-8",
      "apiKey": "env:ANTHROPIC_API_KEY"
    }
  },
  "notify": { "targets": ["console", "discord"] },
  "firstRunLimit": 5,
  "collect": {
    "maxContentChars": 800000,
    "fetchArticleBody": true,
    "articleBodyMinChars": 400,
    "perHostMinIntervalMs": 4000
  },
  "curation": {
    "rankByScore": true,
    "groupReleaseSeries": true,
    "enrichAttention": true,
    "sources": {
      "hfPapers": true,
      "semanticScholar": true,
      "github": true
    },
    "fetchTimeoutMs": 15000,
    "weights": {
      "recency": 0.4,
      "attention": 0.4,
      "content": 0.2
    },
    "recencyHalfLifeDays": 7,
    "demoteFactor": 0.3
  },
  "wiki": {
    "enabled": true,
    "vaultPath": "data/wiki",
    "defaultTags": ["signalseeker"]
  },
  "runtime": {
    "http": {
      "llmChatTimeoutMs": 6000000,
      "llmTestTimeoutMs": 50000,
      "rssTimeoutMs": 20000,
      "discordTimeoutMs": 150000,
      "discordRetryUnitMs": 1000
    },
    "playwright": {
      "navTimeoutMs": 30000,
      "articleTimeoutMs": 25000
    },
    "summarize": {
      "maxOutputTokens": 8000,
      "maxRetries": 2,
      "retryBackoffMs": 3000
    },
    "logging": {
      "dir": "data/logs",
      "level": "info",
      "maxIoChars": 0
    }
  }
}
