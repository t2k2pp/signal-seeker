# Claude API キー(LLM provider が anthropic のとき必須)
ANTHROPIC_API_KEY=sk-ant-...

# Discord 通知先(チャンネルごとに別の投稿先)。
# 各チャンネルの config.json の notify.discordWebhookEnv で参照する環境変数名を指定する。
# 未設定のチャンネルは Discord 送信をスキップ(警告のみ)。
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy   # ai-tech(AI・技術)
DISCORD_WEBHOOK_US_STOCKS=
DISCORD_WEBHOOK_JP_ECONOMY=
DISCORD_WEBHOOK_JP_COMPANIES=

# 注目度シグナル取得の任意トークン(未設定でも動作。設定すると上限緩和・取得成功率向上)
#   GITHUB_TOKEN : GitHub star/reaction の取得上限を 60→5000 req/h に緩和
#   S2_API_KEY   : Semantic Scholar 引用数の取得(無いと429になりやすい)
GITHUB_TOKEN=
S2_API_KEY=
